# OPENROUTER_API_KEY: Required for all AI features (Study Buddy explain/quiz/interview).
# Get one at https://openrouter.ai/keys — a single key routes to any supported model.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL: Optional. Defaults to openrouter/auto (the Auto Router picks
# the best model per prompt). Set any model id from https://openrouter.ai/models
# to pin one instead.
# OPENROUTER_MODEL="openrouter/auto"

# OPENROUTER_QUIZ_MODEL: Optional. The quiz endpoint requires a model that
# supports strict structured outputs (json_schema). Defaults to OPENROUTER_MODEL;
# pin a schema-capable model here if quiz generation fails under the Auto Router.
# OPENROUTER_QUIZ_MODEL="google/gemini-3.5-flash"

# APP_URL: The URL where this app is hosted (used for self-referential links).
APP_URL="MY_APP_URL"

# PREMIUM_SERVICE_URL: Optional. Base URL of the premium content service.
# When set, the app shows locked teasers for premium guided modules
# (marketing data only). Leave unset to hide all premium UI.
# PREMIUM_SERVICE_URL="http://localhost:4000"
