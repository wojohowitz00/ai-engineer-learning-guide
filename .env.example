# ============================================================================
# LLM backend — any OpenAI-compatible server. Four supported setups:
#
# 1) Ollama local (default — free local models, no key needed):
#      ollama pull gemma3 && ollama serve
#    Nothing to configure; optionally pin a model with LLM_MODEL.
#
# 2) Ollama Cloud (hosted — for servers that can't store model weights, e.g.
#    small VPS deployments; https://docs.ollama.com/cloud): create a key at
#    https://ollama.com/settings/keys and set OLLAMA_API_KEY — the app
#    detects it and switches automatically (default model gemma3:12b).
#
# 3) LM Studio (free local models): start its server, then set
#      LLM_BASE_URL="http://localhost:1234/v1"
#      LLM_MODEL="<model id from LM Studio>"
#
# 4) OpenRouter (hosted, paid): set OPENROUTER_API_KEY — auto-detected.
#      https://openrouter.ai/keys
# ============================================================================

# Base URL of the OpenAI-compatible server. Default: http://localhost:11434/v1
# (Ollama) — or OpenRouter automatically when OPENROUTER_API_KEY is set.
# LLM_BASE_URL="http://localhost:11434/v1"

# Model id. Default: "gemma3" locally, "openrouter/auto" on OpenRouter.
# LLM_MODEL="gemma3"

# API keys. Not needed for local Ollama/LM Studio. OLLAMA_API_KEY switches to
# Ollama Cloud; OPENROUTER_API_KEY switches to OpenRouter; LLM_API_KEY is the
# generic override for custom LLM_BASE_URL setups.
# OLLAMA_API_KEY=""
# OPENROUTER_API_KEY=""
# LLM_API_KEY=""

# The quiz endpoint requires json_schema structured-output support. If quiz
# generation fails under your chosen model, pin a schema-capable one here.
# LLM_QUIZ_MODEL="gemma3"

# APP_URL: The URL where this app is hosted (used for self-referential links).
APP_URL="MY_APP_URL"

# PREMIUM_SERVICE_URL: Optional. Base URL of the premium content service.
# When set, the app shows locked teasers for premium guided modules
# (marketing data only). Leave unset to hide all premium UI.
# PREMIUM_SERVICE_URL="http://localhost:4000"
